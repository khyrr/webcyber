# Flask
SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=production

# PostgreSQL
POSTGRES_DB=webcyber
POSTGRES_USER=webcyber
POSTGRES_PASSWORD=change-me

# SQLAlchemy — built from the postgres vars above
DATABASE_URL=postgresql://webcyber:change-me@db:5432/webcyber

# Gunicorn tuning (optional)
GUNICORN_WORKERS=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60
